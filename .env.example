APP_NAME=CentralCloud
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR
APP_MAINTENANCE_DRIVER=database
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=centralcloud
DB_USERNAME=centralcloud
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@centralcloud.example"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=eur
CASHIER_CURRENCY_LOCALE=fr_FR

CENTRALCLOUD_AGENT_CLIENT_CERT=
CENTRALCLOUD_AGENT_CLIENT_KEY=
CENTRALCLOUD_AGENT_CA_CERT=
CENTRALCLOUD_AGENT_ALLOWED_CIDRS=
CENTRALCLOUD_AGENT_ALLOWED_PORTS=443,9443
CENTRALCLOUD_AGENT_CONNECT_TIMEOUT=5
CENTRALCLOUD_AGENT_TIMEOUT=20

CENTRALPANEL_IMAGE=
CENTRALPANEL_DOMAIN_SUFFIX=panels.centralcloud.fr
CENTRALPANEL_HEALTH_PATH=/up
CENTRALPANEL_HEALTH_TIMEOUT=60

CENTRALCLOUD_NODE_OFFLINE_AFTER=35
CENTRALCLOUD_SCHEDULER_RAM_MARGIN=536870912
CENTRALCLOUD_SCHEDULER_DISK_MARGIN=5368709120
CENTRALCLOUD_NODE_MAXIMUM_DEPLOYMENTS=50
CENTRALCLOUD_PAYMENT_GRACE_DAYS=7

CENTRALCLOUD_CRON_USERNAME=centralcloud-cron
CENTRALCLOUD_CRON_SECRET=
CENTRALCLOUD_DEV_ADMIN_EMAIL=
CENTRALCLOUD_DEV_ADMIN_PASSWORD=

VITE_APP_NAME="${APP_NAME}"
